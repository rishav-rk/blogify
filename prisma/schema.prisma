// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

enum USER_TYPE {
  none
  user
  admin
}

enum TOKEN_TYPE {
  access
  forgotpassword
}

enum DEVICE_TYPE {
  android
  ios
  web
}

model User {
  id String @id @default(cuid())
  email String @unique
  name String
  password String
  image String @default("https://t3.ftcdn.net/jpg/05/57/20/16/360_F_557201692_P86sh0v8g00VseZacjBOOKJmGLSvEpQb.jpg")

  isDeleted Boolean @default(false)
  isActive Boolean @default(false)
  isBlocked Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  posts Post[]
  comments Comment[]
  tokens Token[]
}

model Post {
  id String @id @default(cuid())
  title String
  description String?
  thumbnail String?
  content String?
  slug String @unique
  category String?
  isPublished Boolean @default(false)
  author String
  authorRelation User @relation(fields: [author], references: [id])

  admin String?
  adminRelation Admin? @relation(fields: [admin], references: [id])
  isUnpublishedbyAdmin Boolean @default(false)

  isDeleted Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([author, isPublished, isDeleted])
  @@index([isPublished, isDeleted])
  comments Comment[]
}

model Comment {
  id String @id @default(cuid())
  content String
  author String
  authorRelation User @relation(fields: [author], references: [id])
  post String
  postRelation Post @relation(fields: [post], references: [id])

  isDeleted Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([post, isDeleted])
}

model Admin {
  id String @id @default(cuid())
  email String @unique
  name String
  password String
  image String @default("https://static.vecteezy.com/system/resources/thumbnails/068/247/324/small/abstract-user-silhouette-icon-representing-person-profile-and-identity-in-digital-spaces-free-png.png")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tokens Token[]
  posts Post[]
}

model Token {
  id         String   @id

  token      String
  role       USER_TYPE
  type       TOKEN_TYPE

  expires    DateTime

  isDeleted  Boolean  @default(false)

  // Relations
  userId     String?
  user       User?    @relation(fields: [userId], references: [id])

  adminId    String?
  admin      Admin?   @relation(fields: [adminId], references: [id])

  // Embedded objects converted into columns
  deviceType  DEVICE_TYPE?
  deviceToken String?
  deviceId    String?

  otpCode        Int?
  otpExpiresAt   DateTime?
  otpIsVerified  Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([deviceToken, deviceId, isDeleted])
}